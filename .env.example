# Copy to .env (repo root) to override compose defaults.
# Everything has a working dev default baked into deploy/compose/compose.yaml;
# nothing here is required for `just up`.

# HMAC key for signed anonymous session cookies. The compose default is a
# fixed dev value — generate your own for anything shared:
#   openssl rand -hex 32
#SESSION_SECRET=6f1c5c85a2f94ce1b1c2f5f0a3d84b1de6a9c0f47d3b82e5a1c4f7092b6d8e13

# Log level for all services (DEBUG, INFO, WARNING, ERROR).
#LOG_LEVEL=INFO

# OTLP endpoint for traces/metrics/logs. Empty/unset = telemetry off.
# `just up-obs` sets this automatically; set it manually only if you run
# the observability profile some other way.
#OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
