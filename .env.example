# Copy to .env for docker-compose. Values below are the in-compose defaults.
# See docs/CONVENTIONS.md for the authoritative list.

# --- messaging ---
NATS_URL=nats://nats:4222
NATS_STREAM=CV

# --- gateway datastores ---
POSTGRES_DSN=postgres://cv:cv@postgres:5432/cv?sslmode=disable
VALKEY_URL=redis://valkey:6379/0

# --- object storage (LocalStack locally; AWS S3 in deployed envs) ---
S3_ENDPOINT=http://localstack:4566
S3_REGION=us-east-1
S3_BUCKET=cv-pdfs
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_USE_PATH_STYLE=true

# --- telemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local,service.version=0.1.0
LOG_LEVEL=info

# --- secret transit ---
SECRET_TTL_SECONDS=300

# --- service addrs ---
GATEWAY_HTTP_ADDR=:8080

# --- BYO provider keys are entered in the UI per request and never stored here.
# Optional default model ids (used when the form leaves "model" blank):
DEFAULT_MODEL_OPENAI=gpt-4o-mini
DEFAULT_MODEL_ANTHROPIC=claude-haiku-4-5
DEFAULT_MODEL_GEMINI=gemini-2.0-flash
DEFAULT_MODEL_OLLAMA=llama3.2
