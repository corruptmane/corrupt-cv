{
  "uid": "cvgen",
  "title": "CV Generator",
  "tags": ["cvgen"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Completed (1h)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(cvgen_jobs_total{status=\"completed\"}[1h]))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0, "noValue": "0" },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failed (1h)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(cvgen_jobs_total{status=\"failed\"}[1h]))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "noValue": "0",
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Job throughput by status",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(cvgen_jobs_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 12 } },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Job duration (end to end)",
      "gridPos": { "x": 0, "y": 5, "w": 8, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(cvgen_job_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cvgen_job_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 12 } },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Service logs",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 10 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "targets": [{ "refId": "A", "expr": "*" }],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
