# One-shot goose migration runner. Build context: repo root.
#   docker build -f deploy/compose/Dockerfile.migrate .
# Doubles as the production migration image (k8s Job): migrations are baked
# in at /migrations. Compose still bind-mounts ./migrations over it so new
# dev migrations don't need a rebuild; the command/DSN live in compose.yaml
# and the k8s Job respectively.
FROM golang:1.26-alpine AS build
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 go install github.com/pressly/goose/v3/cmd/goose@latest

FROM alpine:3.22
COPY --from=build /go/bin/goose /usr/local/bin/goose
COPY migrations /migrations
USER nobody
ENTRYPOINT ["goose"]
